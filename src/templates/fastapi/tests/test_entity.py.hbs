import pytest
from fastapi.testclient import TestClient


def test_create_{{snakeCase name}}(client: TestClient) -> None:
    response = client.post(
        "/api/v1/{{snakeCase name}}s/",
        json={{{testJson fields}}},
    )
    assert response.status_code == 201
    data = response.json()
    assert "id" in data


def test_get_{{snakeCase name}}(client: TestClient) -> None:
    create_resp = client.post("/api/v1/{{snakeCase name}}s/", json={{{testJson fields}}})
    assert create_resp.status_code == 201
    item_id = create_resp.json()["id"]

    response = client.get(f"/api/v1/{{snakeCase name}}s/{item_id}")
    assert response.status_code == 200
    data = response.json()
    assert data["id"] == item_id


def test_list_{{snakeCase name}}s(client: TestClient) -> None:
    response = client.get("/api/v1/{{snakeCase name}}s/")
    assert response.status_code == 200
    assert isinstance(response.json(), list)


def test_update_{{snakeCase name}}(client: TestClient) -> None:
    create_resp = client.post("/api/v1/{{snakeCase name}}s/", json={{{testJson fields}}})
    assert create_resp.status_code == 201
    item_id = create_resp.json()["id"]

    response = client.put(f"/api/v1/{{snakeCase name}}s/{item_id}", json={{{testJson fields}}})
    assert response.status_code == 200


def test_delete_{{snakeCase name}}(client: TestClient) -> None:
    create_resp = client.post("/api/v1/{{snakeCase name}}s/", json={{{testJson fields}}})
    assert create_resp.status_code == 201
    item_id = create_resp.json()["id"]

    response = client.delete(f"/api/v1/{{snakeCase name}}s/{item_id}")
    assert response.status_code == 204
