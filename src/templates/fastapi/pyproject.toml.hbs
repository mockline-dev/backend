[build-system]
requires = ["setuptools>=68.0.0", "wheel"]
build-backend = "setuptools.backends.legacy:build"

[project]
name = "{{snakeCase projectName}}"
version = "0.1.0"
description = "{{description}}"
requires-python = ">=3.11"
dependencies = [
    "fastapi=={{versions.fastapi}}",
    "uvicorn[standard]=={{versions.uvicorn}}",
    "sqlalchemy=={{versions.sqlalchemy}}",
    "alembic=={{versions.alembic}}",
    "pydantic=={{versions.pydantic}}",
    "pydantic-settings=={{versions.pydantic-settings}}",
    "python-multipart=={{versions.python-multipart}}",
    "psycopg2-binary=={{versions.psycopg2-binary}}",
    "httpx=={{versions.httpx}}",
{{#if authRequired}}
    "python-jose[cryptography]=={{versions.python-jose}}",
    "passlib[bcrypt]=={{versions.passlib}}",
    "bcrypt=={{versions.bcrypt}}",
    "email-validator=={{versions.email-validator}}",
{{/if}}
{{#each externalPackages}}
    "{{this}}",
{{/each}}
]

[project.optional-dependencies]
dev = [
    "pytest=={{versions.pytest}}",
    "pytest-asyncio=={{versions.pytest-asyncio}}",
    "httpx=={{versions.httpx}}",
    "pyflakes=={{versions.pyflakes}}",
]

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]

[tool.pyflakes]
max-line-length = 100
